{
  "name": "sdd-ui-plugin",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "sdd-ui-plugin",
      "version": "0.1.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@sdd-ui/adapters": {
      "resolved": "packages/adapters",
      "link": true
    },
    "node_modules/@sdd-ui/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@sdd-ui/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@sdd-ui/ui-bmad": {
      "resolved": "packages/ui-bmad",
      "link": true
    },
    "node_modules/@sdd-ui/ui-gsd": {
      "resolved": "packages/ui-gsd",
      "link": true
    },
    "node_modules/@sdd-ui/ui-spec-kit": {
      "resolved": "packages/ui-spec-kit",
      "link": true
    },
    "packages/adapters": {
      "name": "@sdd-ui/adapters",
      "version": "0.1.0",
      "dependencies": {
        "@sdd-ui/core": "0.1.0"
      }
    },
    "packages/cli": {
      "name": "@sdd-ui/cli",
      "version": "0.1.0",
      "dependencies": {
        "@sdd-ui/adapters": "0.1.0",
        "@sdd-ui/core": "0.1.0"
      },
      "bin": {
        "sdd-ui": "bin/sdd-ui.js"
      }
    },
    "packages/core": {
      "name": "@sdd-ui/core",
      "version": "0.1.0"
    },
    "packages/ui-bmad": {
      "name": "@sdd-ui/ui-bmad",
      "version": "0.1.0"
    },
    "packages/ui-gsd": {
      "name": "@sdd-ui/ui-gsd",
      "version": "0.1.0"
    },
    "packages/ui-spec-kit": {
      "name": "@sdd-ui/ui-spec-kit",
      "version": "0.1.0"
    }
  }
}
